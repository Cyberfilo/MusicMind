# MusicMind Web — Environment Variables
# Copy to .env and fill in your values.
# All variables use the MUSICMIND_ prefix.

# ──────────────────────────────────────────
# Core (required unless using --sandbox)
# ──────────────────────────────────────────
MUSICMIND_DATABASE_URL=postgresql+asyncpg://musicmind:musicmind@localhost:5432/musicmind
MUSICMIND_FERNET_KEY=           # python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MUSICMIND_JWT_SECRET_KEY=       # python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# ──────────────────────────────────────────
# Sandbox mode (optional)
# ──────────────────────────────────────────
# Set to "true" to start with dev defaults (no secrets needed).
# MUSICMIND_SANDBOX=true

# ──────────────────────────────────────────
# Spotify OAuth (optional — for Spotify features)
# ──────────────────────────────────────────
# Register at https://developer.spotify.com/dashboard
MUSICMIND_SPOTIFY_CLIENT_ID=
MUSICMIND_SPOTIFY_CLIENT_SECRET=
# IMPORTANT: Must go through the frontend (not direct to backend) for session cookies to work
MUSICMIND_SPOTIFY_REDIRECT_URI=http://localhost:3000/api/services/spotify/callback

# ──────────────────────────────────────────
# Apple Music (optional — for Apple Music features)
# ──────────────────────────────────────────
# From https://developer.apple.com/account/resources/authkeys
MUSICMIND_APPLE_TEAM_ID=
MUSICMIND_APPLE_KEY_ID=
MUSICMIND_APPLE_PRIVATE_KEY_PATH=       # Path to your .p8 key file

# ──────────────────────────────────────────
# Frontend URL (for OAuth redirects back to the app)
# ──────────────────────────────────────────
# Local: http://localhost:3000
# Tunnel: https://your-domain.dev
MUSICMIND_FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────
# CORS (optional — extra allowed origins)
# ──────────────────────────────────────────
# Comma-separated list of additional origins. localhost:3000 is always allowed.
# MUSICMIND_CORS_ORIGINS=https://live.menghi.dev,https://your-domain.dev

# ──────────────────────────────────────────
# Application
# ──────────────────────────────────────────
MUSICMIND_DEBUG=false
MUSICMIND_LOG_LEVEL=INFO

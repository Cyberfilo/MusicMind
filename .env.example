# MusicMind Web Environment Variables
# Copy to .env and fill in values

# Database connection (used by backend and Alembic)
MUSICMIND_DATABASE_URL=postgresql+asyncpg://musicmind:musicmind@localhost:5432/musicmind

# Fernet encryption key for secrets at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MUSICMIND_FERNET_KEY=

# Debug mode (set to true for development)
MUSICMIND_DEBUG=false

# Log level
MUSICMIND_LOG_LEVEL=INFO

# Frontend Environment Variables
# Copy to .env.local for local development.
# In Vercel, set these via Project Settings > Environment Variables.

# Backend URL — where the FastAPI backend is running.
# Local dev: http://localhost:8000 (default, no need to set)
# Production: https://your-backend.railway.app (or wherever you deploy the backend)
BACKEND_URL=http://localhost:8000

# Optional: set NEXT_PUBLIC_API_URL to call backend directly instead of via rewrites.
# Leave empty to use Next.js rewrites (recommended — avoids CORS issues).
# NEXT_PUBLIC_API_URL=
